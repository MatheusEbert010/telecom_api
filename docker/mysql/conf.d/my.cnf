[mysqld]
# Mantem o banco acessivel apenas via rede local do host e da rede Docker.
bind-address = 0.0.0.0

# Evita custo de resolucao reversa de DNS nas conexoes.
skip-name-resolve

# Define charset padrao consistente para a aplicacao.
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Ajuda a lidar melhor com conexoes simultaneas em ambiente local.
max_connections = 150

# Torna o log menos verboso em operacao normal.
log_error_verbosity = 2

[client]
default-character-set = utf8mb4
